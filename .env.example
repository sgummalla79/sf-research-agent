# LLM API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
PERPLEXITY_API_KEY=your_perplexity_api_key_here
GOOGLE_API_KEY=your_google_ai_studio_api_key_here

# ── Database backend ─────────────────────────────────────────────────────────
# Switch between backends by changing DB_BACKEND — no code changes needed.
#
# Option 1: SQLite (zero-config, great for local dev and testing)
DB_BACKEND=sqlite
SQLITE_PATH=data/agent.db
#
# Option 2: Local Docker PostgreSQL
# DB_BACKEND=postgres
# POSTGRES_URI=postgresql://agent:agent@localhost:5432/research_agent
#
# Option 3: Cloud PostgreSQL (Supabase / Neon / Railway / RDS)
# DB_BACKEND=postgres
# POSTGRES_URI=postgresql://user:password@host:5432/dbname?sslmode=require

# Model selection (override defaults if needed)
CLAUDE_MODEL=claude-sonnet-4-6
PERPLEXITY_MODEL=sonar-pro
GEMINI_MODEL=gemini-2.5-pro

# CORS — comma-separated list of allowed origins (use * for dev only)
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com

# Discovery — agent asks as many questions as needed; this is only a safety cap
MAX_DISCOVERY_QUESTIONS=30

# Session lifecycle + DB pool
SESSION_TTL_DAYS=15
DB_POOL_SIZE=20      # increase to 30 for 100/day target

# File upload limits (local filesystem)
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
MAX_PDF_PAGES=50
