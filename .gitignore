# ── Python ────────────────────────────────────────────────
.venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage

# ── Environment & secrets (NEVER commit) ──────────────────
# .env          — committed (APP_ENV selector only)
# .env.dev      — committed (dev concrete values)
# .env.test     — committed (test concrete values)
# .env.staging  — NEVER commit (real staging secrets)
# .env.prod     — NEVER commit (real prod secrets)
.env.staging
.env.prod
.env.production
.env.local
.env.*.local

# ── Runtime data ──────────────────────────────────────────
# SQLite database (root or backend/)
data/
backend/data/
# User-uploaded files (root or backend/)
uploads/
backend/uploads/

# ── Vue / Node ────────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/

# ── OS ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── Editors ───────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── Claude Code ───────────────────────────────────────────
.claude/

# ── Logs ──────────────────────────────────────────────────
