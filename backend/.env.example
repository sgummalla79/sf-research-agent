# ── Auth (shared with Express server) ────────────────────────────────────────
# Copy the exact same JWT_SECRET value from express-server/.env.
# Express signs short-lived service tokens with this secret; FastAPI validates them.
# Leave empty to run standalone in dev mode (all requests → "dev-user").
# JWT_SECRET=<same value as express-server JWT_SECRET>

# ── Encryption secret ─────────────────────────────────────────────────────────
# Generate once — keep this secret, it protects the API keys stored in the DB.
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SETTINGS_SECRET=your_fernet_key_here

# ── Database ──────────────────────────────────────────────────────────────────
# The backend is chosen automatically from the URL scheme:
#   postgresql:// or postgres://  →  PostgreSQL
#   (empty / unset)               →  SQLite  ← default for local dev, no setup needed
#
# SQLite (zero-config, local dev)
# DATABASE_URL=          ← leave empty to use SQLite at SQLITE_PATH
# SQLITE_PATH=data/agent.db
#
# Neon (serverless PostgreSQL — copy the connection string from your Neon dashboard)
# DATABASE_URL=postgresql://user:password@ep-xxx-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
#
# Supabase
# DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
#
# Local Docker
# DATABASE_URL=postgresql://agent:agent@localhost:5432/research_agent

# ── API keys ──────────────────────────────────────────────────────────────────
# API keys for LLM providers are configured via Settings → Providers in the UI.
# They are stored encrypted in the database using SETTINGS_SECRET.
# Do NOT set provider keys here.

# ── Tuning (optional) ─────────────────────────────────────────────────────────
# CLAUDE_HAIKU_MODEL=claude-haiku-4-5-20251001   # model used for session title generation
# DB_POOL_SIZE=10        # max PostgreSQL connections (increase for high concurrency)
# MAX_DISCOVERY_QUESTIONS=30
# SESSION_TTL_DAYS=15
# UPLOAD_DIR=uploads
# MAX_FILE_SIZE_MB=10
# MAX_PDF_PAGES=50

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com
