# ── Encryption ────────────────────────────────────────────────────────────────
# Generate once — protects all API keys stored in the DB.
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SETTINGS_SECRET=your_fernet_key_here

# ── Database (PostgreSQL only) ────────────────────────────────────────────────
# Local Docker (matches docker-compose.yml)
DATABASE_URL=postgresql://pragna:your_db_password@localhost:5432/pragna
DB_PASSWORD=your_db_password

# Production examples:
# Neon:     DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/pragna?sslmode=require
# Supabase: DATABASE_URL=postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres

# ── Session ───────────────────────────────────────────────────────────────────
# HS256 secret for signing httpOnly session cookies (openssl rand -hex 32)
JWT_SECRET=change-me-to-a-long-random-secret

# ── Auth0 ─────────────────────────────────────────────────────────────────────
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_spa_client_id
AUTH0_CLIENT_SECRET=your_spa_client_secret
AUTH0_CALLBACK_URL=http://localhost:5173/callback

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com

# ── Frontend URL (local dev only) ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Tuning (optional) ─────────────────────────────────────────────────────────
# CLAUDE_HAIKU_MODEL=claude-haiku-4-5-20251001
# DB_POOL_SIZE=10
# MAX_DISCOVERY_QUESTIONS=30
# MAX_REVISIONS=5
# UPLOAD_DIR=uploads
# MAX_FILE_SIZE_MB=10
# MAX_PDF_PAGES=50
# LOG_LEVEL=INFO
