# ── .env.dev — Local development environment ──────────────────────────────────
# Safe to commit. Contains dev-only secrets — DO NOT use in production.
# Copy this to .env and fill in your Auth0 credentials to get started.

# ── Encryption ────────────────────────────────────────────────────────────────
SETTINGS_SECRET=dE0IgwTAAb3YOELqMo4FqtGGaXo7zau0S1g_uupWc6A=

# ── Database ──────────────────────────────────────────────────────────────────
# Local Docker Postgres (start with: ./scripts/local-db.sh start)
DATABASE_URL=postgresql://pragna:pragna_dev@localhost:5432/pragna
DB_PASSWORD=pragna_dev

# ── Session ───────────────────────────────────────────────────────────────────
JWT_SECRET=cb0415ae1a2e16463092e01442e0f90d2a87f9b5bd8f64bccbb4ec6450bf4bab

# ── Auth0 ─────────────────────────────────────────────────────────────────────
# Fill in your own Auth0 app credentials (dev tenant)
AUTH0_DOMAIN=your-dev-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_dev_client_id
AUTH0_CLIENT_SECRET=your_dev_client_secret
AUTH0_CALLBACK_URL=http://localhost:5173/auth/callback

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

