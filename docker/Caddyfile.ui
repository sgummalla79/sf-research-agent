:80 {
    root * /usr/share/caddy

    # index.html must never be cached — it references hashed JS/CSS filenames
    # that change on every build. Without this, browsers serve stale bundles.
    @html path *.html /
    header @html Cache-Control "no-cache, no-store, must-revalidate"

    # Hashed assets (JS, CSS, images) can be cached forever — their filenames
    # change when content changes, so stale cache is never a problem.
    @assets path /assets/*
    header @assets Cache-Control "public, max-age=31536000, immutable"

    try_files {path} /index.html
    file_server
}
