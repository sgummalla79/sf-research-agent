{
  "name": "sf-research-agent",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.js",
    "dev:mac": "node scripts/dev.js",
    "dev:win": "node scripts/dev.js",
    "dev:frontend:mac": "node scripts/preflight-frontend.js && cd frontend && npm install --silent && npm run dev",
    "dev:frontend:win": "node scripts/preflight-frontend.js && cd frontend && npm install --silent && npm run dev",
    "build:mac": "cd frontend && npm run build",
    "build:win": "cd frontend && npm run build",
    "stop:mac": "npm run stop:frontend:mac",
    "stop:win": "npm run stop:frontend:win",
    "stop:frontend:mac": "lsof -ti:5173 | xargs kill -9 2>/dev/null || true",
    "stop:frontend:win": "powershell -Command \"Get-NetTCPConnection -LocalPort 5173 -ErrorAction SilentlyContinue | ForEach-Object { Stop-Process -Id $_.OwningProcess -Force -ErrorAction SilentlyContinue }\"",
    "test": "cd frontend && npm run test"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
